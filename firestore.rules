rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function getUserRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil;
    }
    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }
    function isOwnUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    match /usuarios/{userId} {
      allow read: if isAdmin() || isOwnUser(userId);
      allow write: if isAdmin() || (isOwnUser(userId) && request.auth != null);
    }
    match /oportunidades/{oppId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.responsableUid == request.auth.uid);
      allow create: if isAdmin() || (request.auth != null && request.resource.data.responsableUid == request.auth.uid);
      allow update: if isAdmin() || (request.auth != null && resource.data.responsableUid == request.auth.uid);
      allow delete: if isAdmin();
    }
    match /counters/{counterId} {
      allow read, write: if request.auth != null;
    }
  }
}
